define i32 @fact(i32 %0) {
entry:
  %n = alloca i32, align 4
  store i32 %0, ptr %n, align 4
  %n1 = load i32, ptr %n, align 4
  %promote = zext i32 %n1 to i64
  %le = icmp sle i64 %promote, 1
  br i1 %le, label %then, label %else

then:                                             ; preds = %entry
  br label %ifcont

else:                                             ; preds = %entry
  %n2 = load i32, ptr %n, align 4
  %n3 = load i32, ptr %n, align 4
  %promote4 = zext i32 %n3 to i64
  %sub = sub i64 %promote4, 1
  %call = call i32 @fact(i64 %sub)
  %mul = mul i32 %n2, %call
  br label %ifcont

ifcont:                                           ; preds = %else, %then
  ret i32 0
}

define i32 @main() {
entry:
  %call = call i32 @fact(i64 5)
  ret i32 %call
}
